#include "./engine/engine.hpp"
#include <GLFW/glfw3.h>
#include <glm/glm.hpp>
#include "./game/game.hpp"
#include "platform/window/GLFWwindow.hpp"
#include "engine/entityManager/component/components.hpp"

class myGame : public Game{
public:
  vec2 v1={10,10};
  vec2 v2={10,10};
  EntityId camera=engine.entityManager.makeCamera();
  EntityId c1 =engine.makeCircle(300, 300, 100);
  EntityId c2 =engine.makeCircle(300, 300, 100);

  void init() override {
    engine.useCamera(camera, engine.getCurrentScene());
    engine.entityManager.setColor(c2,255,0,0,55);
    engine.setTargetFPS(60);
  }


  void update(double) override {
    auto pos = engine.entityManager.getPos(c1);
    if(pos.x+100 > Screen::width) v1.x=-10;
    else if (pos.x-100<0)v1.x=10;
    if(pos.y+100 > Screen::height) v1.y=-10;
    else if (pos.y-100<0)v1.y=10;
    engine.entityManager.setPos(c1,{pos.x+v1.x,pos.y+v1.y,0.0f});
    pos = engine.entityManager.getPos(c2);
    if(pos.x+100 > Screen::width) v2.x=-10;
    else if (pos.x-100<0)v2.x=10;
    if(pos.y+100 > Screen::height) v2.y=-10;
    else if (pos.y-100<0)v2.y=10;
    engine.entityManager.setPos(c2,{pos.x+v2.x,pos.y+v2.y,2.0f});

  };
};

int main() {
  myGame game;
  game.run();
  return 0;
}
